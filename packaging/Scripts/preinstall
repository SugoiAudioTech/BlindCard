#!/bin/bash
# ===========================================
# BlindCard Preinstall Script
# 清除用戶級舊插件，避免版本衝突
# ===========================================

# 取得當前登入用戶
CONSOLE_USER=$(stat -f %Su /dev/console)
USER_HOME=$(dscl . -read /Users/"$CONSOLE_USER" NFSHomeDirectory | awk '{print $2}')

echo "BlindCard Installer: Cleaning up old user-level plugins..."

# 清除用戶級 AU 插件
if [ -d "$USER_HOME/Library/Audio/Plug-Ins/Components/Blind Card.component" ]; then
    echo "Removing old AU: $USER_HOME/Library/Audio/Plug-Ins/Components/Blind Card.component"
    rm -rf "$USER_HOME/Library/Audio/Plug-Ins/Components/Blind Card.component"
fi

# 清除用戶級 VST3 插件
if [ -d "$USER_HOME/Library/Audio/Plug-Ins/VST3/Blind Card.vst3" ]; then
    echo "Removing old VST3: $USER_HOME/Library/Audio/Plug-Ins/VST3/Blind Card.vst3"
    rm -rf "$USER_HOME/Library/Audio/Plug-Ins/VST3/Blind Card.vst3"
fi

echo "BlindCard Installer: Cleanup complete."
exit 0
