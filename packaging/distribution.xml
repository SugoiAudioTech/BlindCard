<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Blind Card v1.0.1</title>
    <organization>com.sugoi</organization>
    <domains enable_localSystem="true"/>
    <options customize="always" require-scripts="false" rootVolumeOnly="true"/>

    <welcome file="welcome.html"/>
    <license file="license.html"/>
    <conclusion file="conclusion.html"/>

    <choices-outline>
        <line choice="au"/>
        <line choice="vst3"/>
        <line choice="standalone"/>
    </choices-outline>

    <choice id="au" title="Audio Unit (AU)" description="Install the AU plugin for Logic Pro, GarageBand, and other AU-compatible hosts.">
        <pkg-ref id="com.sugoi.blindcard.au"/>
    </choice>

    <choice id="vst3" title="VST3" description="Install the VST3 plugin for Ableton Live, Cubase, and other VST3-compatible hosts.">
        <pkg-ref id="com.sugoi.blindcard.vst3"/>
    </choice>

    <choice id="standalone" title="Standalone App" description="Install the standalone application (no DAW required).">
        <pkg-ref id="com.sugoi.blindcard.standalone"/>
    </choice>

    <pkg-ref id="com.sugoi.blindcard.au" version="1.0.1" onConclusion="none">BlindCard-AU.pkg</pkg-ref>
    <pkg-ref id="com.sugoi.blindcard.vst3" version="1.0.1" onConclusion="none">BlindCard-VST3.pkg</pkg-ref>
    <pkg-ref id="com.sugoi.blindcard.standalone" version="1.0.1" onConclusion="none">BlindCard-Standalone.pkg</pkg-ref>
</installer-gui-script>
